<%- include('partials/header') %>
<main>
    <h1><%- title %></h1>

    <section class="categories-list">
        <p>Please select a service project category:</p>
        <ul>
            <% categories.forEach(category => { %>
                <li>
                    <a href="/category/<%= category.category_id %>">
                        <%= category.name %>
                    </a>
                </li>>
            <% }); %>
        </ul>
    </section>
</main>