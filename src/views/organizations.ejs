<%- include('partials/header') %>

    <main>
        <h1><%= title %></h1>
        <p>Here are a few of our partner organizations:</p>
        <ul>
            <% organizations.forEach(organization => { %>
            <li>
                <% if (organization.logo_filename) { %>
                    <img src="/images/<%= organization.logo_filename %>" alt="<%= organization.name %> logo">
                <% } %>
                <br>
                <a href="/organization/<%= organization.organization_id %>"><%= organization.name %></a>
                <br>
                Contact Email: <%= organization.contact_email %></li>
        <% }); %>
        </ul>
    </main>

<%- include('partials/footer') %>